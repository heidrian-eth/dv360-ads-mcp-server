# === Authentication ===
# Two options: Service Account JSON or Application Default Credentials (ADC).
# If both are set, service account takes priority. To force ADC, set DV360_AUTH_MODE=adc.

# Option 1: Service Account JSON (inline)
# DV360_SERVICE_ACCOUNT={"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":""}

# Option 2: Application Default Credentials
# Pre-generate with: gcloud auth application-default login --scopes=https://www.googleapis.com/auth/display-video.readonly,https://www.googleapis.com/auth/doubleclickbidmanager
# Then point to the file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/adc-credentials.json

# Auth mode: "auto" (default, tries service account then ADC), "service_account", or "adc"
# DV360_AUTH_MODE=auto

# === DV360 Configuration ===
# DV360 Partner ID (optional - used as default for list_advertisers)
# Find this in your DV360 URL: https://displayvideo.google.com/ng_nav/p/[PARTNER_ID]/...
# DV360_PARTNER_ID=<your-Partner-ID>
